│   ├── add/                      # quick.tsx · itemized.tsx · transfer.tsx
│   ├── group/[id].tsx            # group detail (Expenses/Balances/Budget/Members)
│   ├── group/[id]/               # budget.tsx · edit.tsx · members.tsx · recurring.tsx
