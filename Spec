## 3. Data model (SQLite)

```sql
-- A real or local person
CREATE TABLE person (
  id            TEXT PRIMARY KEY,      -- uuid
  name          TEXT NOT NULL,
  avatar_color  TEXT NOT NULL,         -- hex e.g. '#E53E3E'
  is_me         INTEGER NOT NULL DEFAULT 0,  -- exactly one row = 1
  remote_uid    TEXT                   -- [v2] Supabase auth uid
);

-- Budget group
CREATE TABLE budget_group (
  id             TEXT PRIMARY KEY,
  name           TEXT NOT NULL,
  icon           TEXT NOT NULL,        -- expo/vector-icons icon name
  color          TEXT NOT NULL,        -- hex
  limit_daily    INTEGER,              -- paise, NULL = no limit
  limit_monthly  INTEGER,
  limit_yearly   INTEGER,
  carry_over     INTEGER NOT NULL DEFAULT 0,  -- 0/1
  is_shared      INTEGER NOT NULL DEFAULT 0,  -- [v2]
  is_archived    INTEGER NOT NULL DEFAULT 0,
  created_at     INTEGER NOT NULL      -- epoch ms
);

-- Many-to-many: group members
CREATE TABLE group_member (
  group_id   TEXT NOT NULL REFERENCES budget_group(id),
  person_id  TEXT NOT NULL REFERENCES person(id),
  PRIMARY KEY (group_id, person_id)
);

-- Transaction
CREATE TABLE txn (
  id             TEXT PRIMARY KEY,
  group_id       TEXT NOT NULL REFERENCES budget_group(id),
  kind           TEXT NOT NULL CHECK(kind IN ('income','expense','settlement')),
  entry_mode     TEXT NOT NULL CHECK(entry_mode IN ('quick','itemized')),
  date           INTEGER NOT NULL,     -- epoch ms
  category       TEXT NOT NULL,
  note           TEXT,
  attachment_uri TEXT,                 -- local file uri for photo
  tags           TEXT,                 -- JSON array e.g. '["#trip","#food"]'
  recur_freq     TEXT CHECK(recur_freq IN ('daily','weekly','monthly','custom')),
  recur_interval INTEGER,              -- e.g. 2 = every 2 weeks
  recur_end      INTEGER,              -- epoch ms, NULL = forever
  is_deleted     INTEGER NOT NULL DEFAULT 0,
  created_at     INTEGER NOT NULL,
  updated_at     INTEGER NOT NULL
);

-- Who paid (one or more rows per txn)
CREATE TABLE txn_payment (
  txn_id     TEXT NOT NULL REFERENCES txn(id),
  person_id  TEXT NOT NULL REFERENCES person(id),
  amount     INTEGER NOT NULL,         -- paise
  PRIMARY KEY (txn_id, person_id)
);

-- Who owes (one or more rows per txn) — stored explicitly, frozen at save
CREATE TABLE txn_share (
  txn_id     TEXT NOT NULL REFERENCES txn(id),
  person_id  TEXT NOT NULL REFERENCES person(id),
  amount     INTEGER NOT NULL,         -- paise
  PRIMARY KEY (txn_id, person_id)
);

-- Line items (itemized entry only)
CREATE TABLE line_item (
  id           TEXT PRIMARY KEY,
  txn_id       TEXT NOT NULL REFERENCES txn(id),
  name         TEXT NOT NULL,
  qty          INTEGER NOT NULL DEFAULT 1,
  unit_price   INTEGER NOT NULL,       -- paise
  assigned_to  TEXT NOT NULL           -- JSON array of person ids; cost split equally among them
);

-- Per-group custom categories
CREATE TABLE category (
  id        TEXT PRIMARY KEY,
  group_id  TEXT NOT NULL REFERENCES budget_group(id),
  name      TEXT NOT NULL,
  icon      TEXT,
  color     TEXT
);
```

**Seeded data on first launch:**

- One `person` row: name from phone (or “Me”), `is_me = 1`
- One `budget_group`: name “Personal”, icon “wallet”, color “#4F46E5”
- One `group_member` linking the two
- Default categories for the Personal group: Food, Groceries, Rent, Utilities, Travel, Fuel, Medical, Shopping, Subscriptions, Other

**Balances are always computed live — never stored:**

```ts
// Per person, per scope (group or global)
net(personId) = Σ txn_payment.amount WHERE person_id = personId
              − Σ txn_share.amount    WHERE person_id = personId
// (over non-deleted txns in scope, excluding income txns from share side)

// net > 0 → this person is owed money
// net < 0 → this person owes money
```

