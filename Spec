## 9. Paise math helpers

```ts
// src/lib/money.ts

/** Format paise as ₹ string: 150050 → "₹1,500.50" */
export function formatRupees(paise: number): string {
  return '₹' + (paise / 100).toLocaleString('en-IN', {
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });
}

/** Parse a user-typed rupee string to paise. "1500.50" → 150050 */
export function parseToPaise(input: string): number {
  const n = parseFloat(input.replace(/[^0-9.]/g, ''));
  if (isNaN(n)) return 0;
  return Math.round(n * 100);
}

/**
 * Split `total` paise equally among `n` people.
 * Returns array of length n summing to exactly total.
 * Remainder paise go to earliest indices.
 */
export function splitEqual(total: number, n: number): number[] {
  if (n === 0) return [];
  const base = Math.floor(total / n);
  const remainder = total - base * n;
  return Array.from({ length: n }, (_, i) => base + (i < remainder ? 1 : 0));
}

/**
 * Apply percentage splits to a total.
 * percentages must sum to 100 (integers, e.g. [50, 30, 20]).
 * Returns amounts summing to exactly total.
 */
export function splitByPercent(total: number, percentages: number[]): number[] {
  const raw = percentages.map(p => Math.floor((total * p) / 100));
  const assigned = raw.reduce((a, b) => a + b, 0);
  let remainder = total - assigned;
  return raw.map((v, i) => {
    if (remainder > 0) { remainder--; return v + 1; }
    return v;
  });
}
```

