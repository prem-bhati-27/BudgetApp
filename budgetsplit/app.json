{
  "expo": {
    "name": "BudgetSplit",
    "slug": "budgetsplit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "budgetsplit",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prem.budgetsplit",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "BudgetSplit can optionally tag a transaction with where you made it. This is off by default and never leaves your device."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F12",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F0A500"
        }
      ],
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BudgetSplit can optionally tag a transaction with where you made it. This is off by default and never leaves your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
