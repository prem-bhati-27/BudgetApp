{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/finance/**",
              "components/ui/**",
              "ui_kits/budgetsplit/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AmountText'] > JSXAttribute > JSXIdentifier[name!=/^(?:paise|size|forceColor|rounded|showSign|style|key|ref|className|style|children)$/]",
        "message": "<AmountText> doesn't accept that prop. Declared props: paise, size, forceColor, rounded, showSign, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AmountText'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xl|lg|md|sm)$/]",
        "message": "<AmountText> size must be one of 'xl' | 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: label, icon, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|income|expense|amber|settle)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'income' | 'expense' | 'amber' | 'settle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BudgetBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:pct|health|height|style|key|ref|className|style|children)$/]",
        "message": "<BudgetBar> doesn't accept that prop. Declared props: pct, health, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BudgetBar'] > JSXAttribute[name.name='health'] > Literal[value!=/^(?:green|amber|red|none)$/]",
        "message": "<BudgetBar> health must be one of 'green' | 'amber' | 'red' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|variant|size|icon|disabled|loading|fullWidth|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: label, children, variant, size, icon, disabled, loading, fullWidth, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padded|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padded, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|color|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CategoryChip> doesn't accept that prop. Declared props: label, icon, color, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|body|actionLabel|onAction|tint|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, body, actionLabel, onAction, tint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FAB'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<FAB> doesn't accept that prop. Declared props: icon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|icon|type|prefix|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, icon, type, prefix, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|amount)$/]",
        "message": "<Input> type must be one of 'text' | 'amount'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MemberAvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|color|size|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MemberAvatar> doesn't accept that prop. Declared props: name, color, size, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SettingsRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|tint|onClick|chevron|right|danger|style|key|ref|className|style|children)$/]",
        "message": "<SettingsRow> doesn't accept that prop. Declared props: icon, label, value, tint, onClick, chevron, right, danger, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: key, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TransactionRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|note|icon|color|paise|kind|onClick|style|key|ref|className|style|children)$/]",
        "message": "<TransactionRow> doesn't accept that prop. Declared props: category, note, icon, color, paise, kind, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TransactionRow'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:expense|income|settlement)$/]",
        "message": "<TransactionRow> kind must be one of 'expense' | 'income' | 'settlement'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
